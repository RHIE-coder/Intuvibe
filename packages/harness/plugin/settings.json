{
  "plugin": {
    "name": "intuvibe-harness",
    "version": "0.1.2"
  },
  "harness": {
    "version": "0.1.2",
    "safety": {
      "block_destructive": true,
      "block_force_push": true,
      "protect_state": true
    },
    "audit": {
      "enabled": true,
      "path": ".harness/state/audit.jsonl",
      "rotate_mb": 10,
      "retention_days": 90,
      "redact_fields": ["email", "password", "token"]
    }
  }
}
