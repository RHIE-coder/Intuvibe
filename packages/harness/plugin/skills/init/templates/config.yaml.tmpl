# Harness Configuration
# Generated by /harness:init

# Workflow mode: standard | prototype | explore
mode: {{mode}}

# Project stack (auto-detected or manually set)
stack:
  language: {{language}}
  framework: {{framework}}

# Workflow settings
workflow:
  right_size: auto

# Testing settings
testing:
  coverage:
    line_min: 80
    branch_min: 70

# Audit settings
audit:
  enabled: true
  rotate_mb: 10
  retention_days: 90
